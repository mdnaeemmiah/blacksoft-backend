APP_NAME=MishiAi Backend
APP_ENV=development
API_PREFIX=/api
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mishiai?retryWrites=true&w=majority&appName=MishiAi
MONGODB_DB=mishiai

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mishiai

# Dashboard administrator. The user is created automatically on startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-password
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=480
VERIFICATION_CODE_MINUTES=10
MAX_CODE_ATTEMPTS=5

# SMTP used for login verification and password reset codes.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Blacksoft Dashboard <no-reply@example.com>
SMTP_USE_TLS=true
